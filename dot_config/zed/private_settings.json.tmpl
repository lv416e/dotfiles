{
  // ===========================================================================
  // Zed Editor Configuration - v1.0 (2026)
  // ===========================================================================
  // Docs: https://zed.dev/docs/configuring-zed
  //
  // Philosophy:
  // - Vim-first workflow (matching Neovim muscle memory)
  // - LSP-powered development (TypeScript, Python, Go, Rust, etc.)
  // - Performance-oriented (GPU acceleration, minimal bloat)
  // - Consistent with existing dotfiles aesthetic
  // ===========================================================================

  // ===========================================================================
  // Agent Panel & External Agents (ACP)
  // ===========================================================================
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],

    // Tool permissions (v0.224.0+ schema, replaces deprecated
    // `always_allow_tool_actions` boolean). Default = confirm; per-tool
    // patterns add guardrails on destructive ops and secret files.
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "terminal": {
          "always_confirm": [
            { "pattern": "^\\s*sudo\\b" },
            { "pattern": "\\brm\\s+-rf\\b" },
            { "pattern": "\\bgit\\s+push\\s+.*--force\\b" },
            { "pattern": "\\bgit\\s+reset\\s+--hard\\b" }
          ]
        },
        "edit_file": {
          "always_deny": [
            { "pattern": "\\.env(\\..+)?$" },
            { "pattern": "\\.age$" },
            { "pattern": "secrets/" },
            { "pattern": "\\.(pem|key|cert)$" }
          ]
        }
      }
    },

    // Model assignments (v1.0): heavy reasoning → Opus, inline edits → Sonnet,
    // commit messages / thread summaries → Haiku for speed + cost.
    "default_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-7"
    },
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6"
    },
    "commit_message_model": {
      "provider": "anthropic",
      "model": "claude-haiku-4-5"
    },
    "thread_summary_model": {
      "provider": "anthropic",
      "model": "claude-haiku-4-5"
    },

    // UX — notify_when_agent_waiting is a string enum: "never" |
    // "primary_screen" | "all_screens" (NOT boolean).
    "notify_when_agent_waiting": "all_screens",
    "play_sound_when_agent_done": false,
    "single_file_review": true
  },
  "agent_servers": {
    "gemini": { "type": "registry" },
    "claude-acp": { "type": "registry" },
    "codex-acp": { "type": "registry" }
  },

  // ===========================================================================
  // MCP Servers (context_servers)
  // ===========================================================================
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": ""
      }
    }
  },

  // ===========================================================================
  // Vim Mode
  // ===========================================================================
  "vim_mode": true,
  "vim": {
    // Use system clipboard for yank/paste (matching Neovim config)
    "use_system_clipboard": "always",
    // Custom digraphs for special characters
    "custom_digraphs": {
      // Add Japanese input helpers if needed
      // Example: "aa": "あ"
    }
  },
  // Relative line numbers (essential for vim motions)
  "relative_line_numbers": "enabled",

  // ===========================================================================
  // Theme & Icons (auto-switch with system appearance)
  // ===========================================================================
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "GitHub Dark Dimmed"
  },
  "icon_theme": {
    "mode": "light",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },

  // ===========================================================================
  // Fonts
  // ===========================================================================
  "buffer_font_family": "HackGen35 Console NF",
  "buffer_font_size": 12,
  "buffer_font_weight": 400,
  "buffer_line_height": {
    "custom": 1.4
  },
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "zero": true
  },
  "ui_font_family": "HackGen35 Console NF",
  "ui_font_size": 13,
  "ui_font_weight": 600,

  // ===========================================================================
  // Cursor & Scroll
  // ===========================================================================
  "cursor_blink": false,
  "scroll_beyond_last_line": "one_page",
  "vertical_scroll_margin": 3,

  // ===========================================================================
  // Indentation & Formatting
  // ===========================================================================
  "tab_size": 2,
  "hard_tabs": false,
  "preferred_line_length": 200,
  "soft_wrap": "none",
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 2,
    "coloring": "indent_aware"
  },
  // Format on save (per-language formatter takes precedence)
  "format_on_save": "on",
  "formatter": "language_server",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,

  // ===========================================================================
  // LSP & Language-Specific Settings
  // ===========================================================================
  // Note: Python uses ruff (LSP + formatter). Type-checking is delegated to
  // mypy via tasks (see tasks.json) — pyright/basedpyright are intentionally
  // disabled in `languages.Python.language_servers` below.
  "lsp": {
    // TypeScript / JavaScript
    "typescript-language-server": {
      "settings": {
        "typescript": {
          "format": { "enable": true },
          "inlayHints": {
            "includeInlayParameterNameHints": "all",
            "includeInlayFunctionParameterTypeHints": true
          }
        }
      }
    },
    // Python — ruff for lint + format. mypy runs via tasks.
    "ruff": {
      "initialization_options": {
        "settings": {
          // Project-level pyproject.toml / ruff.toml will override.
          "lint": {
            "preview": true
          },
          "format": {
            "preview": true
          }
        }
      }
    },
    // Go (gopls)
    "gopls": {
      "settings": {
        "gopls": {
          "analyses": {
            "unusedparams": true,
            "shadow": true
          },
          "staticcheck": true
        }
      }
    },
    // Rust (rust-analyzer)
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "allFeatures": true
        },
        "checkOnSave": true,
        "check": {
          "command": "clippy"
        },
        "inlayHints": {
          "parameterHints": { "enable": true },
          "typeHints": { "enable": true }
        }
      }
    }
  },

  // Per-language configuration
  "languages": {
    "TypeScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": [
        { "code_action": "source.organizeImports" },
        "prettier"
      ],
      "language_servers": [
        "typescript-language-server",
        "!vtsls",
        "..."
      ]
    },
    "JavaScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": [
        { "code_action": "source.organizeImports" },
        "prettier"
      ],
      "language_servers": [
        "typescript-language-server",
        "!vtsls",
        "..."
      ]
    },
    "JSON": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "Python": {
      "tab_size": 4,
      "format_on_save": "on",
      // ruff only — disable pyright/basedpyright (they conflict with ruff/mypy
      // workflow and produce noisy warnings without project pyrightconfig).
      "language_servers": [
        "ruff",
        "!pyright",
        "!basedpyright",
        "!pylsp",
        "..."
      ],
      "formatter": [
        {
          "code_actions": {
            "source.organizeImports.ruff": true,
            "source.fixAll.ruff": true
          }
        },
        { "language_server": { "name": "ruff" } }
      ]
    },
    "Go": {
      "tab_size": 4,
      "hard_tabs": true,
      "format_on_save": "on"
    },
    "Rust": {
      "tab_size": 4,
      "format_on_save": "on"
    },
    "Shell Script": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["-i", "2", "-"]
        }
      }
    },
    "Markdown": {
      "tab_size": 2,
      "format_on_save": "on",
      "soft_wrap": "none",
      "preferred_line_length": 80
    },
    "YAML": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "TOML": {
      "tab_size": 2,
      "format_on_save": "on"
    }
  },

  // ===========================================================================
  // File Management
  // ===========================================================================
  "autosave": "on_focus_change",
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/node_modules",
    "**/.venv",
    "**/venv",
    "**/__pycache__",
    "**/target",
    "**/.DS_Store",
    "**/.idea",
    "**/.vscode"
  ],

  // ===========================================================================
  // Git Integration
  // ===========================================================================
  "git": {
    "enabled": true,
    "inline_blame": {
      "enabled": true
    }
  },
  "git_panel": {
    "dock": "left"
  },
  "gutter": {
    "line_numbers": true,
    "code_actions": true,
    "folds": true,
    "runnables": true,
    "breakpoints": true
  },

  // ===========================================================================
  // Terminal Integration
  // ===========================================================================
  "terminal": {
    "shell": {
      "program": "/bin/zsh"
    },
    "font_family": "HackGen35 Console NF",
    "font_size": 11,
    "working_directory": "current_project_directory",
    "blinking": "off",
    "copy_on_select": false
  },

  // ===========================================================================
  // Debugger (DAP, v1.0)
  // ===========================================================================
  "debugger": {
    "dock": "bottom",
    "save_breakpoints": true,
    "stepping_granularity": "line",
    "button": true,
    "log_dap_communications": false
  },

  // ===========================================================================
  // AI & Edit Predictions
  // ===========================================================================
  "edit_predictions": {
    "disabled_globs": [
      "**/.env*",
      "**/*.age",
      "**/secrets/**",
      "**/*.pem",
      "**/*.key",
      "**/*.cert"
    ]
  },

  // ===========================================================================
  // Performance & Behavior
  // ===========================================================================
  "restore_on_startup": "last_workspace",
  "auto_update": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "restore_unsaved_buffers": true
  },

  // ===========================================================================
  // Panels & UI
  // ===========================================================================
  "collaboration_panel": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "left",
    "git_status": true,
    "indent_size": 20,
    "default_width": 240
  },
  "outline_panel": {
    "dock": "right",
    "default_width": 300
  },
  "minimap": {
    "show": "auto",
    "thumb": "always"
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "close_position": "right"
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": true,
    "show_tab_bar_buttons": true
  },

  // ===========================================================================
  // Search & Navigation
  // ===========================================================================
  "file_finder": {
    "file_icons": true
  },
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_file_finder": true
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true
  },

  // ===========================================================================
  // Diagnostics & Hints
  // ===========================================================================
  "diagnostics": {
    "include_warnings": true
  },
  // Inlay hints — schema is `enabled` + debounce timings (per Zed v1.0).
  // Per-language fine-grained toggles live under `lsp.<server>.initialization_options`.
  "inlay_hints": {
    "enabled": true,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50
  }

  // ===========================================================================
  // Extensions (Auto-install on first launch)
  // ===========================================================================
  // Extensions are managed separately via Zed's extension system
  // Recommended:
  // - Dockerfile, TOML, Just, Prisma, Tailwind CSS
  // ===========================================================================
}
